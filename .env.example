# ============================================================
# Flag-Fest · Variables de entorno
# Copia este archivo a `.env.local` y completa los valores.
# ============================================================

# URL del proyecto Supabase (pública)
NEXT_PUBLIC_SUPABASE_URL=

# Clave anónima de Supabase (pública, uso en cliente)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clave service_role de Supabase (SECRETA — solo servidor).
# Nunca la expongas en componentes cliente ni con prefijo NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# URL pública de la aplicación (para enlaces en correos/PDF).
APP_URL=http://localhost:3000

# Secreto para firmar/verificar los tokens QR (SECRETO — solo servidor).
QR_SECRET=
